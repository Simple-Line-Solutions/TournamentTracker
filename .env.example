JWT_SECRET=replace_this_secret
ADMIN_USER=admin
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrador
PORT=4000
DATABASE_URL=postgresql://postgres:devpass123@localhost:5432/tournament_db
NODE_ENV=development

# Tipos de instalacion: club | circuit
INSTALLATION_MODE=club

# Habilitar funcionalidades de circuito (requiere INSTALLATION_MODE=circuit)
CIRCUIT_ENABLED=false

# Habilitar tipos de torneos (americano,largo)
ALLOWED_TOURNAMENT_TYPES=americano
MIN_TOURNAMENT_PAIRS=6
MAX_TOURNAMENT_PAIRS=24
